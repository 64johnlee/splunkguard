# Google Gemini API key — https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Splunk MCP Server endpoint (from the Splunk MCP Server app in your Splunk instance)
# Format: https://<your-splunk-host>/services/mcp/v1
SPLUNK_MCP_ENDPOINT=https://your-splunk-host.example.com/services/mcp/v1

# Splunk encrypted MCP token (generated in the Splunk MCP Server app, NOT a plain API token)
SPLUNK_MCP_TOKEN=your_encrypted_mcp_token_here

# Optional: Splunk instance label for reports
SPLUNK_INSTANCE_LABEL=my-splunk
